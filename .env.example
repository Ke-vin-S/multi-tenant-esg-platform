# --- Database ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/esg_dev"
DIRECT_URL="postgresql://postgres:password@localhost:5432/esg_dev"
# Privileged user with `app.bypass_rls = on` configured at the role level.
# Used ONLY by the globalPrisma client (Corporate Analyst + Global Admin).
DATABASE_URL_PRIVILEGED="postgresql://esg_privileged:password_privileged@localhost:5432/esg_dev"

# --- Auth (AWS Cognito) ---
NEXT_PUBLIC_COGNITO_USER_POOL_ID=""
NEXT_PUBLIC_COGNITO_CLIENT_ID=""
NEXT_PUBLIC_COGNITO_DOMAIN=""
COGNITO_REGION="ap-south-1"
# App client secret — server-side only, never NEXT_PUBLIC_
COGNITO_CLIENT_SECRET=""
# Password assigned to all seeded Cognito test users (must meet your pool's password policy)
COGNITO_SEED_PASSWORD="SeedTest1!"

# --- File storage (AWS S3) ---
AWS_S3_BUCKET="your-s3-bucket-name"
AWS_S3_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# When DEV_S3_LOCAL=true and AWS credentials are absent, evidence uploads
# are written to ./tmp/evidence/ and served from /api/evidence/[key].
DEV_S3_LOCAL="false"
